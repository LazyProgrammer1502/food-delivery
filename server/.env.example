# ── Server ──────────────────────────────────────────────
PORT=5004
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/food-delivery?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ── Cloudinary ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Client ───────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Restaurant info (used in API responses) ──────────────
RESTAURANT_NAME=Faizan's Kitchen
RESTAURANT_PHONE=+92-300-1234567
